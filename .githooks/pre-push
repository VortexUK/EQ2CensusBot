#!/bin/sh
# Pre-push checks — runs automatically before every `git push`.
# Activate once with:  git config core.hooksPath .githooks
set -e

# Ensure Node.js is on PATH (git bash on Windows doesn't inherit it)
export PATH="/c/Program Files/nodejs:$PATH"

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
RESET='\033[0m'

echo ""
echo "${CYAN}Running pre-push checks…${RESET}"
echo ""

# ── 1. TypeScript type-check ──────────────────────────────────────────────────
echo "${CYAN}→ TypeScript (tsc -b)${RESET}"
cd frontend
if ! ./node_modules/.bin/tsc -b; then
  echo ""
  echo "${RED}✗ TypeScript errors found. Push aborted.${RESET}"
  exit 1
fi
cd ..
echo "${GREEN}  ✓ TypeScript OK${RESET}"

# ── 2. Python syntax check ────────────────────────────────────────────────────
echo "${CYAN}→ Python syntax (compileall)${RESET}"
if ! python -m compileall -q census web bot image scripts 2>/dev/null; then
  echo ""
  echo "${RED}✗ Python syntax errors found. Push aborted.${RESET}"
  exit 1
fi
echo "${GREEN}  ✓ Python OK${RESET}"

# ── 3. Python formatting (ruff) ───────────────────────────────────────────────
echo "${CYAN}→ Python formatting (ruff format --check)${RESET}"
if ! python -m ruff format --check .; then
  echo ""
  echo "${RED}✗ Formatting issues found. Run: python -m ruff format .${RESET}"
  exit 1
fi
echo "${GREEN}  ✓ ruff format OK${RESET}"

# ── 4. Python lint (ruff check) ──────────────────────────────────────────────
echo "${CYAN}→ Python lint (ruff check)${RESET}"
if ! python -m ruff check .; then
  echo ""
  echo "${RED}✗ Lint errors found. Run: python -m ruff check --fix .${RESET}"
  exit 1
fi
echo "${GREEN}  ✓ ruff lint OK${RESET}"

# ── 5. Python type checking (pyright) ────────────────────────────────────────
echo "${CYAN}→ Python types (pyright)${RESET}"
if ! python -m pyright; then
  echo ""
  echo "${RED}✗ Pyright type errors found. Push aborted.${RESET}"
  exit 1
fi
echo "${GREEN}  ✓ pyright OK${RESET}"

# ── 6. Python tests (pytest) ─────────────────────────────────────────────────
echo "${CYAN}→ Python tests (pytest)${RESET}"
if ! python -m pytest --tb=short -q; then
  echo ""
  echo "${RED}✗ Tests failed. Push aborted.${RESET}"
  exit 1
fi
echo "${GREEN}  ✓ pytest OK${RESET}"

echo ""
echo "${GREEN}All checks passed.${RESET}"
echo ""
