#!/bin/sh
# Pre-push checks — runs automatically before every `git push`.
# Activate once with:  git config core.hooksPath .githooks
set -e

# Ensure Node.js is on PATH (git bash on Windows doesn't inherit it)
export PATH="/c/Program Files/nodejs:$PATH"

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
RESET='\033[0m'

echo ""
echo "${CYAN}Running pre-push checks…${RESET}"
echo ""

# uv must be on PATH — install with `pip install uv` or via the installer at
# https://astral.sh/uv. `uv run` ensures every tool below resolves to the
# project-pinned version from uv.lock instead of whatever happens to be on PATH.
if ! command -v uv >/dev/null 2>&1; then
  echo "${RED}✗ uv is not on PATH. Install it: https://docs.astral.sh/uv/${RESET}"
  exit 1
fi

# ── 1. TypeScript type-check ──────────────────────────────────────────────────
echo "${CYAN}→ TypeScript (tsc -b)${RESET}"
cd frontend
if ! ./node_modules/.bin/tsc -b; then
  echo ""
  echo "${RED}✗ TypeScript errors found. Push aborted.${RESET}"
  exit 1
fi
echo "${GREEN}  ✓ TypeScript OK${RESET}"

# ── 1b. Frontend tests (vitest) ───────────────────────────────────────────────
echo "${CYAN}→ Frontend tests (vitest)${RESET}"
if ! ./node_modules/.bin/vitest run --reporter=dot; then
  echo ""
  echo "${RED}✗ Frontend tests failed. Push aborted.${RESET}"
  exit 1
fi
cd ..
echo "${GREEN}  ✓ vitest OK${RESET}"

# ── 2. Python formatting (ruff) ───────────────────────────────────────────────
echo "${CYAN}→ Python formatting (ruff format --check)${RESET}"
if ! uv run --frozen ruff format --check .; then
  echo ""
  echo "${RED}✗ Formatting issues found. Run: uv run ruff format .${RESET}"
  exit 1
fi
echo "${GREEN}  ✓ ruff format OK${RESET}"

# ── 3. Python lint (ruff check) ──────────────────────────────────────────────
echo "${CYAN}→ Python lint (ruff check)${RESET}"
if ! uv run --frozen ruff check .; then
  echo ""
  echo "${RED}✗ Lint errors found. Run: uv run ruff check --fix .${RESET}"
  exit 1
fi
echo "${GREEN}  ✓ ruff lint OK${RESET}"

# ── 4. Python type checking (pyright) ────────────────────────────────────────
echo "${CYAN}→ Python types (pyright)${RESET}"
if ! uv run --frozen pyright; then
  echo ""
  echo "${RED}✗ Pyright type errors found. Push aborted.${RESET}"
  exit 1
fi
echo "${GREEN}  ✓ pyright OK${RESET}"

# ── 5. Python tests (pytest) ─────────────────────────────────────────────────
echo "${CYAN}→ Python tests (pytest)${RESET}"
if ! uv run --frozen pytest --tb=short -q; then
  echo ""
  echo "${RED}✗ Tests failed. Push aborted.${RESET}"
  exit 1
fi
echo "${GREEN}  ✓ pytest OK${RESET}"

echo ""
echo "${GREEN}All checks passed.${RESET}"
echo ""
