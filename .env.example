# Copy this to .env and fill in your values
DISCORD_TOKEN=your_discord_bot_token_here
# Optional: get a service ID from https://census.daybreakgames.com/
# Using "example" works but is rate-limited
CENSUS_SERVICE_ID=your_service_id_here
# EverQuest 2 world/server name for guild lookups
EQ2_WORLD=Varsoon
# Optional: cap item lookups by name to items usable at or below this level.
# Set to the current TLE expansion's max level (e.g. 70 for Echoes of Faydwer).
# If unset, no level filtering is applied.
# SERVER_MAX_LEVEL=70
